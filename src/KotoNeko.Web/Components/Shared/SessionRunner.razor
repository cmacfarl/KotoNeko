@inject ReviewService ReviewService
@inject IJSRuntime JS
@implements IAsyncDisposable

@if (Session is null)
{
    <div class="kn-session-done">
        <p class="kn-empty">Nothing to do here right now.</p>
        <a class="kn-btn kn-btn-primary" href="/">Back to dashboard</a>
    </div>
}
else if (Session.IsComplete)
{
    <div class="kn-session-done">
        <div class="big">🎉</div>
        <h1>@(Session.Kind == SessionKind.Lesson ? "Lessons complete!" : "Reviews complete!")</h1>
        <p>
            @Session.TotalCards item@(Session.TotalCards == 1 ? "" : "s") finished
            @if (Session.Kind == SessionKind.Review)
            {
                <span>— <span style="color:var(--kn-correct-dark);font-weight:600">@Session.CorrectCount correct</span>,
                <span style="color:var(--kn-incorrect-dark);font-weight:600">@Session.IncorrectCount with mistakes</span></span>
            }
        </p>
        <a class="kn-btn kn-btn-primary" href="/">Back to dashboard</a>
    </div>
}
else
{
    ReviewCard card = _displayCard;
    ReviewQuestion q = _displayQuestion;

    <div class="kn-quiz">
        <div class="kn-quiz-header">
            <button class="kn-quiz-exit" title="End session" @onclick="ExitAsync">✕</button>
            <div class="kn-quiz-progress">
                <div class="kn-quiz-progress-fill" style="width:@(ProgressPercent)%"></div>
            </div>
            <div class="kn-quiz-counts">
                <span class="ok">@Session.FinishedCards</span> / @Session.TotalCards done
            </div>
        </div>

        <div class="kn-prompt @PromptClass(q)">
            <div class="kn-prompt-main">
                <div class="kn-prompt-word">
                    @if (card.Vocabulary.ShowsFurigana) {
                        <ruby>@card.Vocabulary.Japanese<rt>@card.Vocabulary.Reading</rt></ruby>
                    } else {
                        @card.Vocabulary.Japanese
                    }
                </div>
                <div class="kn-prompt-type">
                    <span class="strong">@q.Prompt</span>
                </div>
            </div>
            
            @if (_mode == Mode.ShowingResult) {
                <div class="kn-extra">
                    @if (q.Type == QuestionType.Reading) {
                        <div class="kn-extra-row"><span class="kn-extra-label"></span> <span class="kn-jp-reading">@card.Vocabulary.Reading</span></div>
                    } else if (q.Type == QuestionType.Conjugation) {
                        <div class="kn-extra-row"><span class="kn-extra-label"></span> <span class="kn-jp-reading">@_lastCorrectAnswer</span></div>
                    } else if (q.Type == QuestionType.Meaning) {
                        <div class="kn-extra-row"><span class="kn-extra-label"></span> <span class="kn-jp">@card.Vocabulary.MeaningsDisplay</span></div>
                    }
                    
                    @if (!string.IsNullOrWhiteSpace(card.Vocabulary.ContextSentence)) {
                        <div class="kn-extra-row"><span class="kn-extra-label">Context</span> @card.Vocabulary.ContextSentence</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(card.Vocabulary.Memo)) {
                        <div class="kn-extra-row"><span class="kn-extra-label">Memo</span> @card.Vocabulary.Memo</div>
                    }
                </div>
            } else {
                <div class="kn-extra">
                    @if (q.Type == QuestionType.Reading) {
                        <div class="kn-extra-row"><span class="kn-extra-label"></span> <span class="kn-jp"></span></div>
                    } else if (q.Type == QuestionType.Conjugation) {
                        <div class="kn-extra-row"><span class="kn-extra-label"></span> <span class="kn-jp"></span></div>
                    } else if (q.Type == QuestionType.Meaning) {
                        <div class="kn-extra-row"><span class="kn-extra-label"></span> <span class="kn-jp"></span></div>
                    }
                    
                    @if (!string.IsNullOrWhiteSpace(card.Vocabulary.ContextSentence)) {
                        <div class="kn-extra-row"><span class="kn-extra-label">Context</span></div>
                    }
                    @if (!string.IsNullOrWhiteSpace(card.Vocabulary.Memo)) {
                        <div class="kn-extra-row"><span class="kn-extra-label">Memo</span></div>
                    }
                </div>
            }
        </div>
        
        <div class="kn-answer @AnswerStateClass @(_shake ? "kn-shake" : "")">
            <input @ref="_inputRef"
                   type="text"
                   value="@_input"
                   data-kn-convert="@(IsKana(q.Type) ? "true" : "false")"
                   placeholder="@Placeholder(q)"
                   autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false"
                   readonly="@(_mode == Mode.ShowingResult)"
                   @onkeydown="OnKeyDown" />
        </div>

        <div class="kn-answer-footer">
            <button class="kn-undo-btn" disabled="@(!Session.CanUndo)" @onclick="UndoAsync" title="Undo last answer (fix a typo)">
                ↶ Undo
            </button>
        </div>

    </div>
}

@code {
    [Parameter] public ReviewSession? Session { get; set; }

    /// <summary>Invoked when the user exits or the session completes (after persist).</summary>
    [Parameter] public EventCallback OnExit { get; set; }

    private enum Mode { AwaitingInput, ShowingResult }

    private Mode _mode = Mode.AwaitingInput;
    private string _input = string.Empty;
    private string answer = string.Empty;
    private bool needsClear = false;
    private bool _shake;
    private string? _closeHint;
    private AnswerJudgment _lastJudgment;
    private string? _lastCorrectAnswer;
    private bool _focusQueued;
    private bool _persisted;
    private ReviewCard? _displayCard;
    private ReviewQuestion? _displayQuestion;
    
    private ElementReference _inputRef;
    private DotNetObjectReference<SessionRunner>? _dotNetRef;
    private bool _kanaAttached;
    private readonly Stack<string> _typedHistory = new();

    private int ProgressPercent =>
        Session is null || Session.TotalCards == 0
            ? 0
            : (int)(100.0 * Session.FinishedCards / Session.TotalCards);

    protected override void OnParametersSet()
    {
        if (Session is not null && Session.CurrentQuestion is not null)
        {
            _displayCard = Session.CurrentCard;
            _displayQuestion = Session.CurrentQuestion;
            _focusQueued = true;
        }
    }

    // Called from JS (kotoneko.kanaInput) after it has converted + displayed the
    // value in the browser. We only mirror it into component state; we do NOT
    // re-render the input here, so the server never pushes the value back and
    // races the user's typing. (No StateHasChanged: JSInvokable calls don't
    // auto-render, which is exactly what we want.)
    [JSInvokable]
    public Task OnKanaInput(string converted)
    {
        if (_mode != Mode.ShowingResult)
        {
            answer = converted;
        }
        return Task.CompletedTask;
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter")
        {
            return;
        }

        if (_mode == Mode.ShowingResult)
        {
            Advance();
            return;
        }

        await SubmitAsync();
    }

    private async Task SubmitAsync()
    {
        if (Session is null || Session.CurrentQuestion is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(answer))
        {
            await ShakeAsync("Type an answer.");
            return;
        }

        // The browser already converted kana answers; re-run the C# converter as
        // the authoritative grading input (idempotent on kana, and a safety net
        // against any client/server drift).
        ReviewQuestion question = Session.CurrentQuestion;
        // _input = IsKana(question.Type) ? RomajiConverter.ToHiragana(_input) : _input;

        SubmitOutcome outcome = Session.Submit(answer);

        if (outcome.Judgment == AnswerJudgment.CloseTryAgain)
        {
            await ShakeAsync("Hmm, not quite — check your input and try again.");
            return;
        }

        // Committed answer: remember the typed text so Undo can restore it.
        _typedHistory.Push(answer);
        _closeHint = null;
        _lastJudgment = outcome.Judgment;
        _lastCorrectAnswer = outcome.CorrectAnswer;
        _mode = Mode.ShowingResult;
    }

    private void Advance()
    {
        _mode = Mode.AwaitingInput;
        _input = string.Empty;
        answer = string.Empty;
        _closeHint = null;
        _focusQueued = true;
        _displayCard = Session?.CurrentCard;
        _displayQuestion = Session?.CurrentQuestion;
        needsClear = true;
    }

    private async Task UndoAsync()
    {
        if (Session is null || !Session.CanUndo)
        {
            return;
        }

        Session.Undo();
        string restored = _typedHistory.Count > 0 ? _typedHistory.Pop() : string.Empty;
        _input = restored;
        _mode = Mode.AwaitingInput;
        _closeHint = "Undone — fix your answer and submit again.";
        _focusQueued = true;
        await Task.CompletedTask;
    }

    private async Task ShakeAsync(string hint)
    {
        _closeHint = hint;
        _shake = true;
        StateHasChanged();
        await Task.Delay(360);
        _shake = false;
    }

    private async Task ExitAsync()
    {
        await PersistAsync();
        await OnExit.InvokeAsync();
    }

    private async Task PersistAsync()
    {
        if (_persisted || Session is null)
        {
            return;
        }

        _persisted = true;
        await ReviewService.PersistAsync(Session.BuildPendingResults());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Persist automatically once the session is finished.
        if (Session is not null && Session.IsComplete && !_persisted) {
            await PersistAsync();
        }

        // Wire the answer box up to the client-side kana converter once it exists.
        // The same <input> element is reused across questions; the per-question
        // data-kn-convert attribute decides whether to convert.
        if (!_kanaAttached && Session?.CurrentQuestion is not null) {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            try {
                await JS.InvokeVoidAsync("kotoneko.kanaInput.attach", _inputRef, _dotNetRef,
                    new { interceptKeys = false });
                _kanaAttached = true;
            } catch (JSException) {
                // ignore; will retry on a later render
            }
        }
        
        if (needsClear) {
            needsClear = false;
            try {
                // Force the DOM to actually be empty
                await JS.InvokeVoidAsync("kotoneko.kanaInput.setValue", _inputRef, "");
            }
            catch { /* ignore */ }
        }
        
        if (_focusQueued) {
            _focusQueued = false;
            try {
                await JS.InvokeVoidAsync("kotoneko.focusSelect", _inputRef);
            } catch (JSException) {
                // ignore focus failures
            }
        }
    }

    private static bool IsKana(QuestionType type) =>
        type is QuestionType.Reading or QuestionType.Conjugation;

    private static string PromptClass(ReviewQuestion q) => q.Type switch
    {
        QuestionType.Meaning => "kn-prompt-meaning",
        QuestionType.Reading => "kn-prompt-reading",
        QuestionType.Conjugation => "kn-prompt-conjugation",
        _ => "kn-prompt-vocab",
    };

    private string AnswerStateClass => _mode == Mode.ShowingResult
        ? (_lastJudgment == AnswerJudgment.Correct ? "correct" : "incorrect")
        : string.Empty;

    private static string Placeholder(ReviewQuestion q) => q.Type switch
    {
        QuestionType.Meaning => "Meaning",
        QuestionType.Reading => "Reading",
        QuestionType.Conjugation => "Conjugated form",
        _ => "",
    };

    public async ValueTask DisposeAsync()
    {
        // Persist progress if the component is torn down mid-session.
        await PersistAsync();

        if (_kanaAttached)
        {
            try
            {
                await JS.InvokeVoidAsync("kotoneko.kanaInput.detach", _inputRef);
            }
            catch (JSException)
            {
                // circuit may already be gone
            }
            catch (InvalidOperationException)
            {
                // no JS runtime
            }
        }
        _dotNetRef?.Dispose();
    }
}
