@page "/vocab/new"
@page "/vocab/{Id:int}"
@inject VocabularyService VocabularyService
@inject SourceService SourceService
@inject KotoNeko.Jisho.JishoClient Jisho
@inject JapaneseTtsService TtsService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@(Id is null ? "Add" : "Edit") vocabulary · KotoNeko</PageTitle>

<h1>@(Id is null ? "Add vocabulary" : "Edit vocabulary")</h1>

@if (_message is not null)
{
    <div class="kn-msg kn-msg-ok">@_message</div>
}
@if (_error is not null)
{
    <div class="kn-msg kn-msg-err">@_error</div>
}

    <div class="kn-panel">
        <div class="kn-grid-2">
            <div class="kn-form-row">
                <label>Vocabulary Item</label>
                <KanaInput Value="@vocab.Japanese"
                           ValueChanged="OnJapaneseChanged"
                           CssClass="kn-input kn-jp"
                           InterceptKeys="true"
                           OnTab="SearchCandidatesAsync"
                           OnEnter="UseKanaOnly" />
                <div class="kn-hint">
                    Type the word in kana. Press <kbd>Tab</kbd> to look up
                    its writing on jisho, or <kbd>Enter</kbd> if it's a kana-only word.
                </div>

                @if (searching)
                {
                    <div class="kn-candidates"><div class="kn-candidates-head">Searching jisho…</div></div>
                }
                else if (candidates.Count > 0)
                {
                    <div class="kn-candidates">
                        <div class="kn-candidates-head">
                            <span>jisho matches for 「@searchedFor」 — pick a writing</span>
                            <button class="kn-btn kn-btn-sm" type="button" @onclick="DismissCandidates" title="Dismiss">✕</button>
                        </div>
                        @foreach (KotoNeko.Jisho.JishoCandidate c in candidates)
                        {
                            KotoNeko.Jisho.JishoCandidate candidate = c;
                            <button class="kn-candidate" type="button" @onclick="() => ApplyCandidate(candidate)">
                                <span class="kn-jp kn-candidate-word">@candidate.DisplayWriting</span>
                                <span class="kn-candidate-reading kn-jp">@candidate.Reading</span>
                                <span class="kn-candidate-meaning">@string.Join("; ", candidate.Meanings.Take(3))</span>
                                @if (candidate.VerbClass != VerbClass.None)
                                {
                                    <span class="kn-candidate-pos">@VerbClassLabel(candidate.VerbClass)</span>
                                }
                            </button>
                        }
                    </div>
                }
            </div>
            <div class="kn-form-row">
                <label>Reading (kana)</label>
                <KanaInput Value="@vocab.Reading" 
                           ValueChanged="@(v => vocab.Reading = v)" 
                           CssClass="kn-input kn-jp" 
                           Disabled="readingLocked" />
                <div class="kn-hint">
                    @if (readingLocked)
                    {
                        <text>Kana-only word — reading copied from the writing. Edit the writing to change it.</text>
                    }
                    else
                    {
                        <text>Romaji is converted to hiragana as you type.</text>
                    }
                </div>
            </div>
        </div>

        <div class="kn-form-row">
            <label>English meanings</label>
            <div class="kn-hint" style="margin-top:0">Any one of these counts as correct in a review. The first is the primary (shown in lists).</div>
            @for (int i = 0; i < meanings.Count; i++)
            {
                int index = i;
                <div style="display:flex;gap:0.5rem;align-items:center;margin-top:0.4rem">
                    <input class="kn-input" id="@(index == 0 ? "kn-first-meaning" : null)" @bind="meanings[index].Text" />
                    <button class="kn-btn kn-btn-sm kn-btn-danger" type="button" @onclick="() => RemoveMeaning(index)" disabled="@(meanings.Count == 1)" title="Remove">✕</button>
                </div>
            }
            <button class="kn-btn kn-btn-sm" type="button" style="margin-top:0.5rem" @onclick="AddMeaning">+ Add meaning</button>
        </div>

        <div class="kn-form-row">
            <label>Alternate readings (optional, ; separated)</label>
            <input class="kn-input" @bind="vocab.AlternateReadings" />
        </div>

        <div class="kn-form-row">
            <label>Context sentence (optional)</label>
            <textarea class="kn-textarea kn-jp" @bind="vocab.ContextSentence"></textarea>
        </div>

        <div class="kn-form-row">
            <label>Memo (optional)</label>
            <textarea class="kn-textarea" @bind="vocab.Memo"></textarea>
        </div>

        <div class="kn-grid-2">
            <div class="kn-form-row">
                <label>Source material</label>
                <select class="kn-select" @bind="vocab.SourceMaterialId">
                    <option value="">— none —</option>
                    @foreach (SourceMaterial s in sources)
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                </select>
            </div>
            <div class="kn-form-row">
                <label>Verb class</label>
                <select class="kn-select" @bind="vocab.VerbClass" @bind:after="OnVerbClassChanged">
                    @foreach (VerbClass vc in Enum.GetValues<VerbClass>())
                    {
                        <option value="@vc">@VerbClassLabel(vc)</option>
                    }
                </select>
            </div>
        </div>

        <div class="kn-form-row">
            <label style="display:flex;align-items:center;gap:0.4rem">
                <input type="checkbox" @bind="vocab.DisplayFurigana" /> Display furigana (show the reading above the kanji; the reading question is not asked)
            </label>
        </div>

        <div class="kn-form-row">
            <label style="display:flex;align-items:center;gap:0.4rem">
                <input type="checkbox" @bind="vocab.IsAsleep" /> Asleep (excluded from lessons and reviews)
            </label>
        </div>

        <div class="kn-form-row">
            <label>Speech audio</label>
            @if (audioError is not null)
            {
                <div class="kn-hint" style="color:var(--kn-incorrect-dark)">@audioError</div>
            }
            @if (pendingWordAudio is not null || pendingSentenceAudio is not null)
            {
                <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:0.4rem">
                    @if (pendingWordAudio is not null)
                    {
                        <button class="kn-btn" type="button" @onclick="PlayWordAudioAsync">▶ Word</button>
                    }
                    @if (pendingSentenceAudio is not null)
                    {
                        <button class="kn-btn" type="button" @onclick="PlaySentenceAudioAsync">▶ Sentence</button>
                    }
                </div>
            }
            @if (vocab.IsVerb && conjugations.Count > 0)
            {
                int conjReady = conjugations.Count(c => c.HasAudio || pendingConjugationAudio.ContainsKey((c.Form, c.Polarity)));
                <div class="kn-hint">@conjReady / @conjugations.Count conjugation clips.</div>
            }
            @if (!HasAllAudio)
            {
                <button class="kn-btn" type="button" @onclick="FetchAudioAsync"
                        disabled="@(fetchingAudio || _busy || string.IsNullOrWhiteSpace(vocab.Japanese))">
                    @(fetchingAudio ? "Fetching…" : "⤓ Fetch Speech")
                </button>
                <div class="kn-hint">Fetches missing TTS audio.</div>
            }
        </div>

        @if (pendingWordAudio is not null && pendingSentenceAudio is not null)
        {
            <div class="kn-form-row">
                <label style="display:flex;align-items:center;gap:0.4rem">
                    <input type="checkbox" @bind="vocab.PlaySentenceAudioInReview" /> Play context sentence audio during reviews (instead of the vocabulary word)
                </label>
            </div>
        }

        <div class="kn-toolbar">
            <button class="kn-btn kn-btn-accent" @onclick="FetchFromJishoAsync" disabled="@_busy">
                @(_busy ? "Fetching…" : "⤓ Fetch from jisho")
            </button>
            <span class="kn-hint">Detects reading + verb class (and fills meaning if blank), then computes conjugations.</span>
        </div>
    </div>

@if (vocab.VerbClass != VerbClass.None)
{
    <div class="kn-panel">
        <h2>Conjugations</h2>
        <div class="kn-toolbar">
            <button class="kn-btn" @onclick="RegenerateConjugations">↻ Recompute from reading</button>
            <span class="kn-hint">Computed locally. Edit any cell to override.</span>
        </div>

        @if (conjugations.Count == 0)
        {
            <p class="kn-empty">No conjugations yet — set the reading and recompute.</p>
        }
        else
        {
            <div class="kn-conj-grid">
                @foreach (EditableConjugation c in conjugations)
                {
                    <div class="kn-conj-cell kn-form-row">
                        <label>@ConjugationLabels.Describe(c.Form, c.Polarity)</label>
                        <input class="kn-input kn-jp" @bind="c.Kana" />
                    </div>
                }
            </div>
        }
    </div>
}

<div class="kn-toolbar">
    <button class="kn-btn kn-btn-primary" @onclick="SaveAsync" disabled="@(!CanSave || _busy)">Save</button>
    <a class="kn-btn" href="/vocab">Cancel</a>
    @if (Id is not null)
    {
        <button class="kn-btn kn-btn-danger" @onclick="DeleteAsync">Delete</button>
    }
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private Vocabulary vocab = new();
    private List<SourceMaterial> sources = new();
    private List<EditableConjugation> conjugations = new();
    private List<MeaningRow> meanings = new() { new MeaningRow() };
    private string? _message;
    private string? _error;
    private bool _busy;

    private byte[]? pendingWordAudio;
    private byte[]? pendingSentenceAudio;
    private Dictionary<(ConjugationForm, Polarity), byte[]> pendingConjugationAudio = new();
    private bool audioChanged;
    private bool fetchingAudio;
    private string? audioError;

    private bool HasAllAudio =>
        (vocab.HasWordAudio || pendingWordAudio is not null)
        && (string.IsNullOrWhiteSpace(vocab.ContextSentence) || vocab.HasSentenceAudio || pendingSentenceAudio is not null)
        && (!vocab.IsVerb || conjugations.Count == 0
            || conjugations.All(c => c.HasAudio || pendingConjugationAudio.ContainsKey((c.Form, c.Polarity))));

    // Tab-to-search candidate list + kana-only reading lock.
    private List<KotoNeko.Jisho.JishoCandidate> candidates = new();
    private string searchedFor = string.Empty;
    private bool searching;
    private bool readingLocked;
    private bool focusMeaningQueued;

    private bool CanSave =>
        !string.IsNullOrWhiteSpace(vocab.Japanese)
        && !string.IsNullOrWhiteSpace(vocab.Reading)
        && meanings.Any(m => !string.IsNullOrWhiteSpace(m.Text));

    protected override async Task OnParametersSetAsync()
    {
        sources = await SourceService.GetAllAsync();

        // Reset transient UI state in case the component instance is reused
        // across an edit -> new navigation.
        candidates = new();
        searching = false;
        readingLocked = false;
        pendingWordAudio = null;
        pendingSentenceAudio = null;
        pendingConjugationAudio = new();
        audioChanged = false;
        audioError = null;
        fetchingAudio = false;

        if (Id is int id)
        {
            Vocabulary? existing = await VocabularyService.GetAsync(id);
            if (existing is null)
            {
                _error = "That vocabulary item no longer exists.";
                return;
            }

            vocab = existing;
            conjugations = existing.Conjugations
                .Select(c => new EditableConjugation { Form = c.Form, Polarity = c.Polarity, Kana = c.ExpectedKana, HasAudio = c.HasAudio })
                .ToList();
            meanings = existing.Meanings
                .OrderBy(m => m.SortOrder)
                .Select(m => new MeaningRow { Text = m.Text })
                .ToList();
            if (meanings.Count == 0)
            {
                meanings.Add(new MeaningRow());
            }

            if (existing.Audio is not null)
            {
                pendingWordAudio = existing.Audio.WordAudio.Length > 0 ? existing.Audio.WordAudio : null;
                pendingSentenceAudio = existing.Audio.SentenceAudio is { Length: > 0 } s ? s : null;
            }
        }
        else
        {
            vocab = new Vocabulary();
            conjugations = new();
            meanings = new() { new MeaningRow() };
        }
    }

    private void AddMeaning()
    {
        meanings.Add(new MeaningRow());
    }

    private void RemoveMeaning(int index)
    {
        if (meanings.Count > 1)
        {
            meanings.RemoveAt(index);
        }
    }

    private void OnVerbClassChanged()
    {
        if (vocab.VerbClass != VerbClass.None && conjugations.Count == 0)
        {
            RegenerateConjugations();
        }
    }

    private void RegenerateConjugations()
    {
        if (vocab.VerbClass == VerbClass.None || string.IsNullOrWhiteSpace(vocab.Reading))
        {
            return;
        }

        IReadOnlyList<ConjugationResult> generated = ConjugationEngine.Generate(vocab.Reading, vocab.VerbClass);
        conjugations = generated
            .Select(g => new EditableConjugation { Form = g.Form, Polarity = g.Polarity, Kana = g.Kana })
            .ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (focusMeaningQueued)
        {
            focusMeaningQueued = false;
            try
            {
                await JS.InvokeVoidAsync("kotoneko.focusById", "kn-first-meaning");
            }
            catch (JSException)
            {
                // ignore focus failures
            }
        }
    }

    // The user typed in the "Japanese writing" field. Any edit invalidates a
    // pending candidate list and unlocks the (kana-only) reading.
    private void OnJapaneseChanged(string value)
    {
        vocab.Japanese = value;
        readingLocked = false;
        if (candidates.Count > 0)
        {
            candidates = new();
        }
    }

    // Tab in the writing field: look up matches for the kana on jisho.
    private async Task SearchCandidatesAsync()
    {
        _error = null;
        _message = null;

        string keyword = vocab.Japanese?.Trim() ?? string.Empty;
        if (keyword.Length == 0)
        {
            return;
        }

        searching = true;
        candidates = new();
        searchedFor = keyword;
        StateHasChanged();
        try
        {
            candidates = (await Jisho.SearchAsync(keyword)).ToList();
            if (candidates.Count == 0)
            {
                _error = "jisho found no matches (or it's unavailable). Press Enter for a kana-only word, or type the writing.";
            }
        }
        finally
        {
            searching = false;
        }
    }

    private void DismissCandidates()
    {
        candidates = new();
    }

    // The user picked a writing from the jisho list.
    private void ApplyCandidate(KotoNeko.Jisho.JishoCandidate c)
    {
        vocab.Japanese = c.DisplayWriting;
        vocab.Reading = c.Reading;
        readingLocked = false;

        if (meanings.Count > 0) {
            meanings.Clear();
        }
        
        bool hasMeanings = meanings.Any(m => !string.IsNullOrWhiteSpace(m.Text));
        if (!hasMeanings && c.Meanings.Count > 0) {
            meanings = c.Meanings.Select(m => new MeaningRow { Text = m }).ToList();
        }

        vocab.VerbClass = c.VerbClass;
        if (c.VerbClass != VerbClass.None) {
            RegenerateConjugations();
        }

        candidates = new();
        focusMeaningQueued = true;
    }

    // Enter in the writing field: it's a kana-only word, so the reading is the
    // same kana. Lock the (now redundant) reading and jump to the meanings.
    private void UseKanaOnly()
    {
        string kana = vocab.Japanese?.Trim() ?? string.Empty;
        if (kana.Length == 0)
        {
            return;
        }

        vocab.Reading = kana;
        readingLocked = true;
        candidates = new();
        focusMeaningQueued = true;
    }

    private async Task FetchAudioAsync()
    {
        audioError = null;
        if (string.IsNullOrWhiteSpace(vocab.Japanese)) {
            audioError = "Enter the Japanese word first.";
            return;
        }

        fetchingAudio = true;
        bool anyFetched = false;
        List<string> errors = new();
        try {
            if (!vocab.HasWordAudio && pendingWordAudio is null) {
                try {
                    pendingWordAudio = (await TtsService.SynthesiseAsync(vocab.Japanese)).Audio;
                    anyFetched = true;
                } catch (Exception ex) { 
                    errors.Add($"Word: {ex.Message}"); 
                }
            }

            if (!string.IsNullOrWhiteSpace(vocab.ContextSentence) && !vocab.HasSentenceAudio && pendingSentenceAudio is null) {
                try {
                    pendingSentenceAudio = (await TtsService.SynthesiseAsync(vocab.ContextSentence)).Audio;
                    anyFetched = true;
                } catch (Exception ex) { 
                    errors.Add($"Sentence: {ex.Message}"); 
                }
            }

            if (vocab.IsVerb) {
                foreach (EditableConjugation c in conjugations) {
                    if (c.HasAudio || pendingConjugationAudio.ContainsKey((c.Form, c.Polarity)) || string.IsNullOrWhiteSpace(c.Kana))
                        continue;
                    try {
                        pendingConjugationAudio[(c.Form, c.Polarity)] = (await TtsService.SynthesiseAsync(c.Kana)).Audio;
                        anyFetched = true;
                    } catch (Exception ex) { 
                        errors.Add($"{ConjugationLabels.Describe(c.Form, c.Polarity)}: {ex.Message}"); 
                    }
                }
            }

            if (anyFetched)
                audioChanged = true;

            if (errors.Count > 0)
                audioError = errors.Count == 1
                    ? $"Fetch failed: {errors[0]}"
                    : $"{errors.Count} fetches failed. First: {errors[0]}";
        } finally {
            fetchingAudio = false;
        }
    }

    private async Task PlayWordAudioAsync()
    {
        if (pendingWordAudio is null) return;
        try { await JS.InvokeVoidAsync("kotoneko.playAudioBytes", pendingWordAudio); }
        catch { }
    }

    private async Task PlaySentenceAudioAsync()
    {
        if (pendingSentenceAudio is null) return;
        try { await JS.InvokeVoidAsync("kotoneko.playAudioBytes", pendingSentenceAudio); }
        catch { }
    }

    private async Task FetchFromJishoAsync()
    {
        _error = null;
        _message = null;

        if (string.IsNullOrWhiteSpace(vocab.Japanese))
        {
            _error = "Enter the Japanese writing first.";
            return;
        }

        _busy = true;
        try
        {
            KotoNeko.Jisho.JishoLookupResult result = await Jisho.LookupAsync(vocab.Japanese);
            if (result.Error is not null)
            {
                _error = $"jisho lookup failed: {result.Error}";
                return;
            }

            if (!result.Found)
            {
                _error = "jisho didn't find that word. Fill the fields manually.";
                return;
            }

            if (!string.IsNullOrWhiteSpace(result.Reading))
            {
                vocab.Reading = result.Reading;
                readingLocked = false;
            }

            // Fill meanings as separate rows if the user hasn't entered any yet.
            bool hasMeanings = meanings.Any(m => !string.IsNullOrWhiteSpace(m.Text));
            if (!hasMeanings && result.Meanings.Count > 0)
            {
                meanings = result.Meanings.Select(m => new MeaningRow { Text = m }).ToList();
            }

            vocab.VerbClass = result.VerbClass;

            if (result.VerbClass != VerbClass.None)
            {
                RegenerateConjugations();
                _message = $"Detected {VerbClassLabel(result.VerbClass)} — reading and conjugations filled in.";
            }
            else
            {
                _message = "Reading filled in. (Not detected as a verb.)";
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SaveAsync()
    {
        _error = null;
        if (!CanSave) {
            _error = "Japanese, reading, and at least one meaning are required.";
            return;
        }

        // The service trims, de-duplicates, drops blanks, and assigns sort order.
        vocab.Meanings = meanings
            .Select(m => new VocabularyMeaning { Text = m.Text })
            .ToList();

        List<ConjugationResult> conjugations = vocab.VerbClass == VerbClass.None
            ? new()
            : this.conjugations
                .Where(c => !string.IsNullOrWhiteSpace(c.Kana))
                .Select(c => new ConjugationResult(c.Form, c.Polarity, c.Kana.Trim()))
                .ToList();

        int savedId = await VocabularyService.SaveAsync(vocab, conjugations);
        if (audioChanged) {
            if (pendingWordAudio is not null)
                await VocabularyService.SaveAudioAsync(savedId, pendingWordAudio, pendingSentenceAudio);
            if (pendingConjugationAudio.Count > 0)
                await VocabularyService.SaveConjugationAudioAsync(savedId, pendingConjugationAudio);
            audioChanged = false;
        }
        Nav.NavigateTo("/vocab");
    }

    private async Task DeleteAsync()
    {
        if (Id is int id)
        {
            await VocabularyService.DeleteAsync(id);
            Nav.NavigateTo("/vocab");
        }
    }

    private static string VerbClassLabel(VerbClass vc) => vc switch
    {
        VerbClass.None => "Not a verb",
        VerbClass.Godan => "Godan (う-verb)",
        VerbClass.Ichidan => "Ichidan (る-verb)",
        VerbClass.Suru => "する verb",
        VerbClass.Kuru => "来る verb",
        _ => vc.ToString(),
    };

    private sealed class EditableConjugation
    {
        public ConjugationForm Form { get; set; }
        public Polarity Polarity { get; set; }
        public string Kana { get; set; } = string.Empty;
        public bool HasAudio { get; set; }
    }

    private sealed class MeaningRow
    {
        public string Text { get; set; } = string.Empty;
    }
}
