@page "/vocab/new"
@page "/vocab/{Id:int}"
@inject VocabularyService VocabularyService
@inject SourceService SourceService
@inject KotoNeko.Jisho.JishoClient Jisho
@inject JapaneseTtsService TtsService
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@(Id is null ? "Add" : "Edit") vocabulary · KotoNeko</PageTitle>

<h1>@(Id is null ? "Add vocabulary" : "Edit vocabulary")</h1>

@if (_message is not null)
{
    <div class="kn-msg kn-msg-ok">@_message</div>
}
@if (_error is not null)
{
    <div class="kn-msg kn-msg-err">@_error</div>
}

    <div class="kn-panel">
        <div class="kn-grid-2">
            <div class="kn-form-row">
                <label>Vocabulary Item</label>
                <KanaInput Value="@_vocab.Japanese"
                           ValueChanged="OnJapaneseChanged"
                           CssClass="kn-input kn-jp"
                           InterceptKeys="true"
                           OnTab="SearchCandidatesAsync"
                           OnEnter="UseKanaOnly" />
                <div class="kn-hint">
                    Type the word in kana. Press <kbd>Tab</kbd> to look up
                    its writing on jisho, or <kbd>Enter</kbd> if it's a kana-only word.
                </div>

                @if (_searching)
                {
                    <div class="kn-candidates"><div class="kn-candidates-head">Searching jisho…</div></div>
                }
                else if (_candidates.Count > 0)
                {
                    <div class="kn-candidates">
                        <div class="kn-candidates-head">
                            <span>jisho matches for 「@_searchedFor」 — pick a writing</span>
                            <button class="kn-btn kn-btn-sm" type="button" @onclick="DismissCandidates" title="Dismiss">✕</button>
                        </div>
                        @foreach (KotoNeko.Jisho.JishoCandidate c in _candidates)
                        {
                            KotoNeko.Jisho.JishoCandidate candidate = c;
                            <button class="kn-candidate" type="button" @onclick="() => ApplyCandidate(candidate)">
                                <span class="kn-jp kn-candidate-word">@candidate.DisplayWriting</span>
                                <span class="kn-candidate-reading kn-jp">@candidate.Reading</span>
                                <span class="kn-candidate-meaning">@string.Join("; ", candidate.Meanings.Take(3))</span>
                                @if (candidate.VerbClass != VerbClass.None)
                                {
                                    <span class="kn-candidate-pos">@VerbClassLabel(candidate.VerbClass)</span>
                                }
                            </button>
                        }
                    </div>
                }
            </div>
            <div class="kn-form-row">
                <label>Reading (kana)</label>
                <KanaInput Value="@_vocab.Reading" 
                           ValueChanged="@(v => _vocab.Reading = v)" 
                           CssClass="kn-input kn-jp" 
                           Disabled="_readingLocked" />
                <div class="kn-hint">
                    @if (_readingLocked)
                    {
                        <text>Kana-only word — reading copied from the writing. Edit the writing to change it.</text>
                    }
                    else
                    {
                        <text>Romaji is converted to hiragana as you type.</text>
                    }
                </div>
            </div>
        </div>

        <div class="kn-form-row">
            <label>English meanings</label>
            <div class="kn-hint" style="margin-top:0">Any one of these counts as correct in a review. The first is the primary (shown in lists).</div>
            @for (int i = 0; i < _meanings.Count; i++)
            {
                int index = i;
                <div style="display:flex;gap:0.5rem;align-items:center;margin-top:0.4rem">
                    <input class="kn-input" id="@(index == 0 ? "kn-first-meaning" : null)" @bind="_meanings[index].Text" />
                    <button class="kn-btn kn-btn-sm kn-btn-danger" type="button" @onclick="() => RemoveMeaning(index)" disabled="@(_meanings.Count == 1)" title="Remove">✕</button>
                </div>
            }
            <button class="kn-btn kn-btn-sm" type="button" style="margin-top:0.5rem" @onclick="AddMeaning">+ Add meaning</button>
        </div>

        <div class="kn-form-row">
            <label>Alternate readings (optional, ; separated)</label>
            <input class="kn-input" @bind="_vocab.AlternateReadings" />
        </div>

        <div class="kn-form-row">
            <label>Context sentence (optional)</label>
            <textarea class="kn-textarea kn-jp" @bind="_vocab.ContextSentence"></textarea>
        </div>

        <div class="kn-form-row">
            <label>Memo (optional)</label>
            <textarea class="kn-textarea" @bind="_vocab.Memo"></textarea>
        </div>

        <div class="kn-grid-2">
            <div class="kn-form-row">
                <label>Source material</label>
                <select class="kn-select" @bind="_vocab.SourceMaterialId">
                    <option value="">— none —</option>
                    @foreach (SourceMaterial s in _sources)
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                </select>
            </div>
            <div class="kn-form-row">
                <label>Verb class</label>
                <select class="kn-select" @bind="_vocab.VerbClass" @bind:after="OnVerbClassChanged">
                    @foreach (VerbClass vc in Enum.GetValues<VerbClass>())
                    {
                        <option value="@vc">@VerbClassLabel(vc)</option>
                    }
                </select>
            </div>
        </div>

        <div class="kn-form-row">
            <label style="display:flex;align-items:center;gap:0.4rem">
                <input type="checkbox" @bind="_vocab.DisplayFurigana" /> Display furigana (show the reading above the kanji; the reading question is not asked)
            </label>
        </div>

        <div class="kn-form-row">
            <label style="display:flex;align-items:center;gap:0.4rem">
                <input type="checkbox" @bind="_vocab.IsAsleep" /> Asleep (excluded from lessons and reviews)
            </label>
        </div>

        <div class="kn-form-row">
            <label>Speech audio</label>
            @if (_audioError is not null)
            {
                <div class="kn-hint" style="color:var(--kn-incorrect-dark)">@_audioError</div>
            }
            @if (_pendingWordAudio is null)
            {
                <button class="kn-btn" type="button" @onclick="FetchAudioAsync"
                        disabled="@(_fetchingAudio || _busy || string.IsNullOrWhiteSpace(_vocab.Japanese))">
                    @(_fetchingAudio ? "Fetching…" : "⤓ Fetch Speech")
                </button>
                <div class="kn-hint">Fetches TTS audio for the word@(!string.IsNullOrWhiteSpace(_vocab.ContextSentence) ? " and context sentence" : "").</div>
            }
            else
            {
                <div style="display:flex;gap:0.5rem;flex-wrap:wrap">
                    <button class="kn-btn" type="button" @onclick="PlayWordAudioAsync">▶ Word</button>
                    @if (_pendingSentenceAudio is not null)
                    {
                        <button class="kn-btn" type="button" @onclick="PlaySentenceAudioAsync">▶ Sentence</button>
                    }
                </div>
            }
        </div>

        @if (_pendingWordAudio is not null && _pendingSentenceAudio is not null)
        {
            <div class="kn-form-row">
                <label style="display:flex;align-items:center;gap:0.4rem">
                    <input type="checkbox" @bind="_vocab.PlaySentenceAudioInReview" /> Play context sentence audio during reviews (instead of the vocabulary word)
                </label>
            </div>
        }

        <div class="kn-toolbar">
            <button class="kn-btn kn-btn-accent" @onclick="FetchFromJishoAsync" disabled="@_busy">
                @(_busy ? "Fetching…" : "⤓ Fetch from jisho")
            </button>
            <span class="kn-hint">Detects reading + verb class (and fills meaning if blank), then computes conjugations.</span>
        </div>
    </div>

@if (_vocab.VerbClass != VerbClass.None)
{
    <div class="kn-panel">
        <h2>Conjugations</h2>
        <div class="kn-toolbar">
            <button class="kn-btn" @onclick="RegenerateConjugations">↻ Recompute from reading</button>
            <span class="kn-hint">Computed locally. Edit any cell to override.</span>
        </div>

        @if (_conjugations.Count == 0)
        {
            <p class="kn-empty">No conjugations yet — set the reading and recompute.</p>
        }
        else
        {
            <div class="kn-conj-grid">
                @foreach (EditableConjugation c in _conjugations)
                {
                    <div class="kn-conj-cell kn-form-row">
                        <label>@ConjugationLabels.Describe(c.Form, c.Polarity)</label>
                        <input class="kn-input kn-jp" @bind="c.Kana" />
                    </div>
                }
            </div>
        }
    </div>
}

<div class="kn-toolbar">
    <button class="kn-btn kn-btn-primary" @onclick="SaveAsync" disabled="@(!CanSave || _busy)">Save</button>
    <a class="kn-btn" href="/vocab">Cancel</a>
    @if (Id is not null)
    {
        <button class="kn-btn kn-btn-danger" @onclick="DeleteAsync">Delete</button>
    }
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private Vocabulary _vocab = new();
    private List<SourceMaterial> _sources = new();
    private List<EditableConjugation> _conjugations = new();
    private List<MeaningRow> _meanings = new() { new MeaningRow() };
    private string? _message;
    private string? _error;
    private bool _busy;

    private byte[]? _pendingWordAudio;
    private byte[]? _pendingSentenceAudio;
    private bool _audioChanged;
    private bool _fetchingAudio;
    private string? _audioError;

    // Tab-to-search candidate list + kana-only reading lock.
    private List<KotoNeko.Jisho.JishoCandidate> _candidates = new();
    private string _searchedFor = string.Empty;
    private bool _searching;
    private bool _readingLocked;
    private bool _focusMeaningQueued;

    private bool CanSave =>
        !string.IsNullOrWhiteSpace(_vocab.Japanese)
        && !string.IsNullOrWhiteSpace(_vocab.Reading)
        && _meanings.Any(m => !string.IsNullOrWhiteSpace(m.Text));

    protected override async Task OnParametersSetAsync()
    {
        _sources = await SourceService.GetAllAsync();

        // Reset transient UI state in case the component instance is reused
        // across an edit -> new navigation.
        _candidates = new();
        _searching = false;
        _readingLocked = false;
        _pendingWordAudio = null;
        _pendingSentenceAudio = null;
        _audioChanged = false;
        _audioError = null;
        _fetchingAudio = false;

        if (Id is int id)
        {
            Vocabulary? existing = await VocabularyService.GetAsync(id);
            if (existing is null)
            {
                _error = "That vocabulary item no longer exists.";
                return;
            }

            _vocab = existing;
            _conjugations = existing.Conjugations
                .Select(c => new EditableConjugation { Form = c.Form, Polarity = c.Polarity, Kana = c.ExpectedKana })
                .ToList();
            _meanings = existing.Meanings
                .OrderBy(m => m.SortOrder)
                .Select(m => new MeaningRow { Text = m.Text })
                .ToList();
            if (_meanings.Count == 0)
            {
                _meanings.Add(new MeaningRow());
            }

            if (existing.Audio is not null)
            {
                _pendingWordAudio = existing.Audio.WordAudio.Length > 0 ? existing.Audio.WordAudio : null;
                _pendingSentenceAudio = existing.Audio.SentenceAudio is { Length: > 0 } s ? s : null;
            }
        }
        else
        {
            _vocab = new Vocabulary();
            _conjugations = new();
            _meanings = new() { new MeaningRow() };
        }
    }

    private void AddMeaning()
    {
        _meanings.Add(new MeaningRow());
    }

    private void RemoveMeaning(int index)
    {
        if (_meanings.Count > 1)
        {
            _meanings.RemoveAt(index);
        }
    }

    private void OnVerbClassChanged()
    {
        if (_vocab.VerbClass != VerbClass.None && _conjugations.Count == 0)
        {
            RegenerateConjugations();
        }
    }

    private void RegenerateConjugations()
    {
        if (_vocab.VerbClass == VerbClass.None || string.IsNullOrWhiteSpace(_vocab.Reading))
        {
            return;
        }

        IReadOnlyList<ConjugationResult> generated = ConjugationEngine.Generate(_vocab.Reading, _vocab.VerbClass);
        _conjugations = generated
            .Select(g => new EditableConjugation { Form = g.Form, Polarity = g.Polarity, Kana = g.Kana })
            .ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusMeaningQueued)
        {
            _focusMeaningQueued = false;
            try
            {
                await JS.InvokeVoidAsync("kotoneko.focusById", "kn-first-meaning");
            }
            catch (JSException)
            {
                // ignore focus failures
            }
        }
    }

    // The user typed in the "Japanese writing" field. Any edit invalidates a
    // pending candidate list and unlocks the (kana-only) reading.
    private void OnJapaneseChanged(string value)
    {
        _vocab.Japanese = value;
        _readingLocked = false;
        if (_candidates.Count > 0)
        {
            _candidates = new();
        }
    }

    // Tab in the writing field: look up matches for the kana on jisho.
    private async Task SearchCandidatesAsync()
    {
        _error = null;
        _message = null;

        string keyword = _vocab.Japanese?.Trim() ?? string.Empty;
        if (keyword.Length == 0)
        {
            return;
        }

        _searching = true;
        _candidates = new();
        _searchedFor = keyword;
        StateHasChanged();
        try
        {
            _candidates = (await Jisho.SearchAsync(keyword)).ToList();
            if (_candidates.Count == 0)
            {
                _error = "jisho found no matches (or it's unavailable). Press Enter for a kana-only word, or type the writing.";
            }
        }
        finally
        {
            _searching = false;
        }
    }

    private void DismissCandidates()
    {
        _candidates = new();
    }

    // The user picked a writing from the jisho list.
    private void ApplyCandidate(KotoNeko.Jisho.JishoCandidate c)
    {
        _vocab.Japanese = c.DisplayWriting;
        _vocab.Reading = c.Reading;
        _readingLocked = false;

        if (_meanings.Count > 0) {
            _meanings.Clear();
        }
        
        bool hasMeanings = _meanings.Any(m => !string.IsNullOrWhiteSpace(m.Text));
        if (!hasMeanings && c.Meanings.Count > 0) {
            _meanings = c.Meanings.Select(m => new MeaningRow { Text = m }).ToList();
        }

        _vocab.VerbClass = c.VerbClass;
        if (c.VerbClass != VerbClass.None) {
            RegenerateConjugations();
        }

        _candidates = new();
        _focusMeaningQueued = true;
    }

    // Enter in the writing field: it's a kana-only word, so the reading is the
    // same kana. Lock the (now redundant) reading and jump to the meanings.
    private void UseKanaOnly()
    {
        string kana = _vocab.Japanese?.Trim() ?? string.Empty;
        if (kana.Length == 0)
        {
            return;
        }

        _vocab.Reading = kana;
        _readingLocked = true;
        _candidates = new();
        _focusMeaningQueued = true;
    }

    private async Task FetchAudioAsync()
    {
        _audioError = null;
        if (string.IsNullOrWhiteSpace(_vocab.Japanese))
        {
            _audioError = "Enter the Japanese word first.";
            return;
        }

        _fetchingAudio = true;
        try
        {
            TtsResult wordResult = await TtsService.SynthesiseAsync(_vocab.Japanese);
            _pendingWordAudio = wordResult.Audio;

            if (!string.IsNullOrWhiteSpace(_vocab.ContextSentence))
            {
                TtsResult sentenceResult = await TtsService.SynthesiseAsync(_vocab.ContextSentence);
                _pendingSentenceAudio = sentenceResult.Audio;
            }

            _audioChanged = true;
        }
        catch (Exception ex)
        {
            _audioError = $"Failed to fetch speech: {ex.Message}";
        }
        finally
        {
            _fetchingAudio = false;
        }
    }

    private async Task PlayWordAudioAsync()
    {
        if (_pendingWordAudio is null) return;
        try { await JS.InvokeVoidAsync("kotoneko.playAudioBytes", _pendingWordAudio); }
        catch { }
    }

    private async Task PlaySentenceAudioAsync()
    {
        if (_pendingSentenceAudio is null) return;
        try { await JS.InvokeVoidAsync("kotoneko.playAudioBytes", _pendingSentenceAudio); }
        catch { }
    }

    private async Task FetchFromJishoAsync()
    {
        _error = null;
        _message = null;

        if (string.IsNullOrWhiteSpace(_vocab.Japanese))
        {
            _error = "Enter the Japanese writing first.";
            return;
        }

        _busy = true;
        try
        {
            KotoNeko.Jisho.JishoLookupResult result = await Jisho.LookupAsync(_vocab.Japanese);
            if (result.Error is not null)
            {
                _error = $"jisho lookup failed: {result.Error}";
                return;
            }

            if (!result.Found)
            {
                _error = "jisho didn't find that word. Fill the fields manually.";
                return;
            }

            if (!string.IsNullOrWhiteSpace(result.Reading))
            {
                _vocab.Reading = result.Reading;
                _readingLocked = false;
            }

            // Fill meanings as separate rows if the user hasn't entered any yet.
            bool hasMeanings = _meanings.Any(m => !string.IsNullOrWhiteSpace(m.Text));
            if (!hasMeanings && result.Meanings.Count > 0)
            {
                _meanings = result.Meanings.Select(m => new MeaningRow { Text = m }).ToList();
            }

            _vocab.VerbClass = result.VerbClass;

            if (result.VerbClass != VerbClass.None)
            {
                RegenerateConjugations();
                _message = $"Detected {VerbClassLabel(result.VerbClass)} — reading and conjugations filled in.";
            }
            else
            {
                _message = "Reading filled in. (Not detected as a verb.)";
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SaveAsync()
    {
        _error = null;
        if (!CanSave)
        {
            _error = "Japanese, reading, and at least one meaning are required.";
            return;
        }

        // The service trims, de-duplicates, drops blanks, and assigns sort order.
        _vocab.Meanings = _meanings
            .Select(m => new VocabularyMeaning { Text = m.Text })
            .ToList();

        List<ConjugationResult> conjugations = _vocab.VerbClass == VerbClass.None
            ? new()
            : _conjugations
                .Where(c => !string.IsNullOrWhiteSpace(c.Kana))
                .Select(c => new ConjugationResult(c.Form, c.Polarity, c.Kana.Trim()))
                .ToList();

        int savedId = await VocabularyService.SaveAsync(_vocab, conjugations);
        if (_audioChanged && _pendingWordAudio is not null)
        {
            await VocabularyService.SaveAudioAsync(savedId, _pendingWordAudio, _pendingSentenceAudio);
            _audioChanged = false;
        }
        Nav.NavigateTo("/vocab");
    }

    private async Task DeleteAsync()
    {
        if (Id is int id)
        {
            await VocabularyService.DeleteAsync(id);
            Nav.NavigateTo("/vocab");
        }
    }

    private static string VerbClassLabel(VerbClass vc) => vc switch
    {
        VerbClass.None => "Not a verb",
        VerbClass.Godan => "Godan (う-verb)",
        VerbClass.Ichidan => "Ichidan (る-verb)",
        VerbClass.Suru => "する verb",
        VerbClass.Kuru => "来る verb",
        _ => vc.ToString(),
    };

    private sealed class EditableConjugation
    {
        public ConjugationForm Form { get; set; }
        public Polarity Polarity { get; set; }
        public string Kana { get; set; } = string.Empty;
    }

    private sealed class MeaningRow
    {
        public string Text { get; set; } = string.Empty;
    }
}
